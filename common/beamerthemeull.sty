}

% Automatic font size selection based on title length
\newdimen\titlewidth
\newcommand{\autosizeframetitle}[1]{%
   \setbox0=\hbox{#1}%
   \titlewidth=\wd0\relax
   \ifdim\titlewidth<6cm\relax
      \vspace{0.15cm}
      \huge#1\strut%
   \else\ifdim\titlewidth<8cm\relax
      \vspace{0.15cm}
      \huge#1\strut%
   \else\ifdim\titlewidth<10cm\relax
      \vspace{0.20cm}
      \LARGE#1\strut%
   \else\ifdim\titlewidth<14cm\relax
      \vspace{0.25cm}
      \Large#1\strut%
   \else
      \vspace{0.30cm}
      \Large#1\strut%
   \fi\fi\fi\fi
} 

