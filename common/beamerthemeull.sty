% Calculate total number of sections for automatic splitting
\newcounter{totalsections}
\AtEndDocument{%
   \immediate\write\@auxout{\string\setcounter{totalsections}{\the\c@section}}%
}

\newcommand{\insertindex}{
   {
      \hypersetup{colorlinks=false,pdfborder={0 0 0}, pdfborderstyle={}}
      \begin{frame}[plain]
         \frametitle{Índice}
         \ifnum\value{totalsections}>1\relax
            \pgfmathtruncatemacro{\midsection}{(\value{totalsections}+1)/2}%
            \pgfmathtruncatemacro{\secondhalf}{\midsection+1}%
            {
               \begin{columns}
                  \begin{column}{.5\textwidth}
                     \tableofcontents[currentsection, currentsubsection, sections={1-\midsection}]
                  \end{column}
                  \begin{column}{.5\textwidth}
                     \tableofcontents[currentsection, currentsubsection, sections={\secondhalf-}]
                  \end{column}
               \end{columns}
            }
         \else
            \tableofcontents[currentsection, currentsubsection]
         \fi
   \end{frame}
   }
}

