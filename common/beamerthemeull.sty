% Stretchy lists (add [s] to the frame)
\define@key{beamerframe}{s}[true]{% stretch
  \beamer@frametopskip=0pt\relax%
  \beamer@framebottomskip=0pt\relax%
  \beamer@frametopskipautobreak=\beamer@frametopskip\relax%
  \beamer@framebottomskipautobreak=\beamer@framebottomskip\relax%
}
\def\beamer@defaultospec{s}

% Stretchy columns (use with [s] frames)
% Content is vertically stretched (good for lists)
% Usage: \begin{column}{width} \stretchycolumn{content} \end{column}
\newcommand{\stretchycolumn}[1]{%
  \begin{minipage}[t][0.8\textheight][s]{\linewidth}%
    #1%
  \end{minipage}%
}

% Centered column (use with [s] frames)
% Content is vertically centered (good for figures)
% Usage: \begin{column}{width} \centeredcolumn{content} \end{column}
\newcommand{\centeredcolumn}[1]{%
  \begin{minipage}[t][0.8\textheight][c]{\linewidth}%
    #1%
  \end{minipage}%
}

% Two-column stretchy environment (use with [s] frames)
% Usage: \stretchytwocols{left content}{right content}
% Left column stretches, right column centers (typical for text + figure)
\newcommand{\stretchytwocols}[2]{%
  \begin{columns}[onlytextwidth,T]%
    \begin{column}{.5\textwidth}%
      \stretchycolumn{#1}%
    \end{column}%
    \begin{column}{.5\textwidth}%
      \centeredcolumn{#2}%
    \end{column}%
  \end{columns}%
}

\newcommand{\twocols}[2]{%
  \begin{columns}[onlytextwidth,T]%
    \begin{column}{.5\textwidth}%
      #1
    \end{column}%
    \begin{column}{.5\textwidth}%
      \centeredcolumn{#2}%
    \end{column}%
  \end{columns}%
}

